---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import BeforeAfter from "@components/BeforeAfter.astro";
import HomeServicePaths from "@components/HomeServicePaths.astro";
import { demoConfig, imageLibrary, siteConfig, stats, testimonials } from "@data/site";

const projects = await getCollection("trabajos");
const featuredCase = projects.find((project) => project.id === "velo-y-memoria") ?? projects[0];
const featuredUrl = `/trabajos/${featuredCase.id}/`;
const featuredYear = featuredCase.data.date.getFullYear();
const featuredQuote = featuredCase.data.testimonial ?? testimonials[0];

const servicePaths = [
  {
    label: "Bodas + retratos",
    title: "Historias personales",
    outcome: "Volver a sentir, no solo volver a mirar.",
    description: "Films, fotografías y retratos con dirección suave y atención a lo que ocurre de verdad.",
    image: imageLibrary.portrait,
    imageAlt: "Retrato editorial realizado con luz natural."
  },
  {
    label: "Marcas",
    title: "Identidad en imágenes",
    outcome: "Comunicar con intención sin perder humanidad.",
    description: "Dirección visual, fotografía y video para marcas que quieren verse cuidadas y cercanas.",
    image: imageLibrary.coffeeCup,
    imageAlt: "Manos sosteniendo una taza de café durante una producción de marca."
  },
  {
    label: "Video + reels",
    title: "Contenido en movimiento",
    outcome: "Ganar atención sin parecerse a todo lo demás.",
    description: "Piezas verticales y audiovisuales con ritmo, coherencia y acabado listo para publicar.",
    image: imageLibrary.production,
    imageAlt: "Cámara profesional durante una producción audiovisual."
  }
];

const processPhases = [
  {
    title: "Conversamos",
    text: "Entendemos la historia, el objetivo y aquello que no debería perderse."
  },
  {
    title: "Creamos",
    text: "Diseñamos la mirada y capturamos con dirección suficiente, sin romper lo natural."
  },
  {
    title: "Entregamos",
    text: "Seleccionamos, editamos y preparamos cada pieza para conservar, compartir o publicar."
  }
];
---

<BaseLayout image={imageLibrary.wedding}>
  <section class="home-hero" aria-labelledby="home-hero-title">
    <div class="home-hero__media">
      <img data-home-parallax src={imageLibrary.wedding} alt="Pareja de novios abrazada bajo luz cálida durante una boda." width="1800" height="1200" loading="eager" />
    </div>
    <div class="container home-hero__content">
      <div class="home-hero__copy">
        <p class="eyebrow">Fotografía + Film · Lima y destinos</p>
        <h1 id="home-hero-title">Historias que vuelven a sentirse.</h1>
        <p>Fotografía y video con una mirada cinematográfica, pensados para conservar lo real y darle una forma que permanezca.</p>
        <div class="hero__actions">
          <a class="button button--light" href="/trabajos/">Explorar historias</a>
          <a class="button button--secondary" href="/contacto/#solicitud">Contar mi proyecto <span aria-hidden="true">↗</span></a>
        </div>
      </div>

      <div class="home-hero__footer">
        <a class="home-hero__featured" href={featuredUrl}>
          <span>Historia seleccionada</span>
          <strong>{featuredCase.data.title}</strong>
          <small>{featuredCase.data.location} · {featuredYear}</small>
          <i aria-hidden="true">↗</i>
        </a>
        <div class="home-hero__scroll" aria-hidden="true"><span></span>Desliza para explorar</div>
      </div>
    </div>
  </section>

  <section class="section home-feature" aria-labelledby="home-feature-title">
    <div class="container">
      <header class="home-section-heading" data-reveal>
        <div>
          <p class="eyebrow">Historia destacada</p>
          <h2 id="home-feature-title">Una historia completa, no solo una imagen bonita.</h2>
        </div>
        <p>Entramos en cada proyecto buscando una emoción, una atmósfera y un ritmo propios. Este caso muestra cómo esas decisiones construyen memoria.</p>
      </header>

      <article class="home-case" data-reveal>
        <a class="home-case__media" href={featuredUrl} aria-label={`Explorar el caso ${featuredCase.data.title}`}>
          <img
            data-home-parallax
            class="home-case__cover"
            src={featuredCase.data.cover}
            alt={featuredCase.data.coverAlt}
            width="1400"
            height="1200"
            loading="lazy"
            style={`view-transition-name: project-${featuredCase.id};`}
          />
          <span class="home-case__detail">
            <img src={featuredCase.data.gallery[1].src} alt={featuredCase.data.gallery[1].alt} width="600" height="800" loading="lazy" />
          </span>
          <span class="home-case__action">Ver caso completo <i aria-hidden="true">↗</i></span>
        </a>

        <div class="home-case__content">
          <div class="home-case__index"><span>01</span><small>Selección editorial</small></div>
          <p class="home-case__kicker">{featuredCase.data.category} · {featuredCase.data.location}</p>
          <h3>{featuredCase.data.title}</h3>
          <p>{featuredCase.data.excerpt}</p>
          <ul aria-label="Atmósfera del proyecto">
            {featuredCase.data.mood.map((item) => <li>{item}</li>)}
          </ul>
          {featuredCase.data.testimonial && <blockquote>“{featuredCase.data.testimonial.quote}”</blockquote>}
          <a class="home-text-link" href={featuredUrl}>Descubrir la historia <span aria-hidden="true">↗</span></a>
        </div>
      </article>
    </div>
  </section>

  <section class="section home-services" aria-labelledby="home-services-title">
    <div class="container">
      <header class="home-section-heading home-section-heading--dark" data-reveal>
        <div>
          <p class="eyebrow">Elige por intención</p>
          <h2 id="home-services-title">El formato cambia. La atención al detalle no.</h2>
        </div>
        <p>Explora tres caminos y descubre cuál se acerca más a lo que quieres recordar, comunicar o poner en movimiento.</p>
      </header>
      <HomeServicePaths paths={servicePaths} />
    </div>
  </section>

  <section class="section home-proof" aria-label="Dirección visual y confianza">
    <div class="container">
      <BeforeAfter
        src={imageLibrary.coffeeBeans}
        alt="Granos de café con un acabado visual cálido y cinematográfico."
      />

      <div class="home-proof__confidence" data-reveal>
        <blockquote>
          <p>“{featuredQuote.quote}”</p>
          <footer><strong>{featuredQuote.author}</strong><span>{featuredQuote.context}</span></footer>
        </blockquote>
        <dl>
          {stats.map((item) => <div><dt>{item.value}</dt><dd>{item.label}</dd></div>)}
        </dl>
      </div>
    </div>
  </section>

  <section class="section home-process" aria-labelledby="home-process-title">
    <div class="container">
      <header class="home-process__heading" data-reveal>
        <div>
          <p class="eyebrow">Una ruta sencilla</p>
          <h2 id="home-process-title">Menos incertidumbre. Más espacio para estar presente.</h2>
        </div>
        <div>
          <p>El proceso está diseñado para que sepas qué ocurre y qué viene después, sin convertir la experiencia en una producción rígida.</p>
          <a class="home-text-link" href="/sobre-mi/">Conocer mi forma de trabajar <span aria-hidden="true">↗</span></a>
        </div>
      </header>

      <ol class="home-process__steps" data-reveal>
        {
          processPhases.map((phase, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{phase.title}</h3>
              <p>{phase.text}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="home-final" aria-labelledby="home-final-title">
    <img data-home-parallax src={imageLibrary.weddingVeil} alt="Pareja bajo un velo en una escena íntima." width="1800" height="1200" loading="lazy" />
    <div class="container home-final__content">
      <div class="home-final__brand">
        <p class="eyebrow">Tu historia empieza aquí</p>
        <h2 id="home-final-title">Lo que importa merece una mirada propia.</h2>
        <p>{siteConfig.responseTime} Cuéntanos lo que estás imaginando y diseñaremos una propuesta alrededor de ello.</p>
        <div class="cta-actions">
          <a class="button button--light" href="/contacto/#solicitud">Consultar disponibilidad <span aria-hidden="true">↗</span></a>
          <a class="button button--secondary" href="/trabajos/">Volver a las historias</a>
        </div>
      </div>

      <aside class="home-creator" aria-label="Información de diseño y desarrollo">
        <div>
          <span>Diseño y desarrollo</span>
          <strong>¿Quieres una experiencia digital con este nivel de detalle?</strong>
        </div>
        <p>Este concepto demuestra cómo una marca visual puede convertirse en una web memorable, responsive y preparada para presentar servicios.</p>
        <a class="button button--light" href={demoConfig.contactUrl} target="_blank" rel="noreferrer">Hablemos de tu web <span aria-hidden="true">↗</span></a>
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  const reduceHomeMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reduceHomeMotion) {
    const parallaxItems = Array.from(document.querySelectorAll<HTMLElement>("[data-home-parallax]"));
    let homeFrame = 0;

    const updateHomeParallax = () => {
      parallaxItems.forEach((item) => {
        const parent = item.parentElement;
        if (!parent) return;
        const rect = parent.getBoundingClientRect();
        if (rect.bottom < -100 || rect.top > window.innerHeight + 100) return;
        const distance = window.innerHeight / 2 - (rect.top + rect.height / 2);
        const shift = Math.max(-28, Math.min(28, distance * 0.055));
        item.style.setProperty("--home-shift", `${shift}px`);
      });
      homeFrame = 0;
    };

    const requestHomeParallax = () => {
      if (homeFrame) return;
      homeFrame = window.requestAnimationFrame(updateHomeParallax);
    };

    window.addEventListener("scroll", requestHomeParallax, { passive: true });
    window.addEventListener("resize", requestHomeParallax);
    updateHomeParallax();
  }
</script>

<style>
  .home-hero {
    position: relative;
    min-height: calc(100svh - 72px);
    display: grid;
    align-items: end;
    overflow: hidden;
    isolation: isolate;
    background: var(--color-ink);
  }

  .home-hero__media {
    position: absolute;
    inset: -3rem 0;
    z-index: -2;
    animation: home-hero-enter 1.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .home-hero__media img,
  .home-final > img,
  .home-case__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate3d(0, var(--home-shift, 0), 0) scale(1.07);
    will-change: transform;
  }

  .home-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(22, 21, 19, 0.88) 0%, rgba(22, 21, 19, 0.6) 48%, rgba(22, 21, 19, 0.12) 100%),
      linear-gradient(0deg, rgba(22, 21, 19, 0.78) 0%, rgba(22, 21, 19, 0.04) 55%);
  }

  .home-hero__content {
    display: grid;
    min-height: calc(100svh - 72px);
    align-content: end;
    padding-block: clamp(4rem, 8vw, 7rem) 1.5rem;
    color: white;
  }

  .home-hero__copy {
    display: grid;
    gap: 1.35rem;
    max-width: 900px;
    padding-bottom: clamp(3rem, 8vh, 6rem);
  }

  .home-hero__copy > * {
    animation: home-copy-enter 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .home-hero__copy > :nth-child(2) { animation-delay: 90ms; }
  .home-hero__copy > :nth-child(3) { animation-delay: 150ms; }
  .home-hero__copy > :nth-child(4) { animation-delay: 210ms; }

  .home-hero .eyebrow,
  .home-final .eyebrow {
    color: var(--color-gold);
  }

  .home-hero h1 {
    max-width: 880px;
    color: white;
    font-size: clamp(4.5rem, 8vw, 8rem);
    letter-spacing: -0.05em;
  }

  .home-hero__copy > p:not(.eyebrow) {
    max-width: 640px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 1.08rem;
  }

  .home-hero__footer {
    display: grid;
    grid-template-columns: minmax(280px, 0.65fr) 1fr;
    gap: 2rem;
    align-items: end;
    border-top: 1px solid rgba(255, 255, 255, 0.23);
    padding-top: 1.2rem;
  }

  .home-hero__featured {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.1rem 1rem;
    max-width: 430px;
    color: white;
  }

  .home-hero__featured > span,
  .home-hero__featured small {
    color: rgba(255, 255, 255, 0.54);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-hero__featured strong {
    font-family: var(--font-serif);
    font-size: 1.4rem;
  }

  .home-hero__featured i {
    grid-column: 2;
    grid-row: 1 / span 3;
    align-self: center;
    font-style: normal;
    font-size: 1.2rem;
  }

  .home-hero__scroll {
    justify-self: end;
    display: flex;
    gap: 0.7rem;
    align-items: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-hero__scroll span {
    width: 3.5rem;
    height: 1px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.3);
  }

  .home-hero__scroll span::after {
    content: "";
    display: block;
    width: 45%;
    height: 100%;
    background: white;
    animation: home-scroll-line 1.8s ease-in-out infinite;
  }

  .home-section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.55fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .home-section-heading h2,
  .home-process__heading h2 {
    max-width: 820px;
    font-size: clamp(3.3rem, 6vw, 6rem);
    letter-spacing: -0.04em;
  }

  .home-section-heading > p,
  .home-process__heading > div:last-child {
    border-left: 1px solid var(--color-line);
    padding-left: 1.4rem;
  }

  .home-case {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(330px, 0.65fr);
    gap: clamp(2.5rem, 7vw, 7rem);
    align-items: center;
  }

  .home-case__media {
    position: relative;
    min-height: 720px;
    overflow: hidden;
    background: var(--color-cream);
  }

  .home-case__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(22, 21, 19, 0.48), transparent 45%);
    pointer-events: none;
  }

  .home-case__detail {
    position: absolute;
    right: 1.4rem;
    bottom: 1.4rem;
    z-index: 1;
    width: 30%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 6px solid white;
  }

  .home-case__detail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-case__action {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    z-index: 1;
    display: inline-flex;
    gap: 0.5rem;
    color: white;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .home-case__action i {
    font-style: normal;
    transition: transform 180ms ease;
  }

  .home-case__media:hover .home-case__action i {
    transform: translate(0.2rem, -0.2rem);
  }

  .home-case__content {
    display: grid;
    gap: 1.25rem;
  }

  .home-case__index {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 1rem;
  }

  .home-case__index span {
    color: var(--color-clay);
    font-family: var(--font-serif);
    font-size: 2rem;
  }

  .home-case__index small,
  .home-case__kicker {
    color: var(--color-muted);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-case__content h3 {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 6vw, 6rem);
  }

  .home-case__content ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .home-case__content li {
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.4rem 0.7rem;
    color: var(--color-muted);
    font-size: 0.7rem;
    font-weight: 800;
  }

  .home-case__content blockquote {
    margin: 1rem 0 0;
    border-top: 1px solid var(--color-line);
    padding-top: 1.2rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 1.35rem;
    line-height: 1.35;
  }

  .home-text-link {
    display: inline-flex;
    gap: 0.4rem;
    justify-self: start;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.2rem;
    font-weight: 800;
  }

  .home-services {
    background: var(--color-ink);
    color: white;
  }

  .home-section-heading--dark h2,
  .home-section-heading--dark p {
    color: white;
  }

  .home-section-heading--dark .eyebrow {
    color: var(--color-gold);
  }

  .home-section-heading--dark > p {
    border-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.64);
  }

  .home-proof {
    overflow: hidden;
    background: var(--color-cream);
  }

  .home-proof :global(.comparison-section) {
    width: 100%;
  }

  .home-proof :global(.comparison) {
    min-height: 620px;
    border-radius: 0;
    box-shadow: none;
  }

  .home-proof__confidence {
    display: grid;
    grid-template-columns: minmax(340px, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(3rem, 8vw, 8rem);
    align-items: end;
    margin-top: 5rem;
    border-top: 1px solid var(--color-line);
    padding-top: 2.5rem;
  }

  .home-proof__confidence blockquote {
    display: grid;
    gap: 1.5rem;
    margin: 0;
  }

  .home-proof__confidence blockquote > p {
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.8vw, 3.5rem);
    line-height: 1.16;
  }

  .home-proof__confidence blockquote footer {
    display: grid;
    font-size: 0.78rem;
  }

  .home-proof__confidence blockquote span {
    color: var(--color-muted);
  }

  .home-proof__confidence dl {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--color-line);
  }

  .home-proof__confidence dl div {
    display: grid;
    gap: 0.3rem;
    border-right: 1px solid var(--color-line);
    padding: 1.3rem 1rem;
  }

  .home-proof__confidence dl div:last-child {
    border-right: 0;
  }

  .home-proof__confidence dt {
    color: var(--color-clay);
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 700;
  }

  .home-proof__confidence dd {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.74rem;
  }

  .home-process__heading {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.55fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
  }

  .home-process__heading > div:last-child {
    display: grid;
    gap: 1.2rem;
  }

  .home-process__steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: 5rem;
    border-top: 1px solid var(--color-line);
  }

  .home-process__steps::after {
    content: "";
    position: absolute;
    top: -1px;
    right: 0;
    left: 0;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left;
    background: var(--color-clay);
    transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .home-process__steps.is-visible::after {
    transform: scaleX(1);
  }

  .home-process__steps li {
    min-height: 300px;
    border-right: 1px solid var(--color-line);
    padding: 2rem 2rem 0 0;
  }

  .home-process__steps li + li {
    padding-left: 2rem;
  }

  .home-process__steps li:last-child {
    border-right: 0;
  }

  .home-process__steps span {
    display: inline-block;
    margin-bottom: 3rem;
    color: var(--color-clay);
    font-family: var(--font-serif);
    font-size: 1.5rem;
  }

  .home-process__steps h3 {
    margin-bottom: 0.8rem;
    font-family: var(--font-serif);
    font-size: 2.2rem;
  }

  .home-process__steps p {
    max-width: 310px;
  }

  .home-final {
    position: relative;
    min-height: 900px;
    display: grid;
    align-items: end;
    overflow: hidden;
    isolation: isolate;
    background: var(--color-ink);
  }

  .home-final > img {
    position: absolute;
    inset: -3rem 0;
    z-index: -2;
  }

  .home-final::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(90deg, rgba(22, 21, 19, 0.92) 0%, rgba(22, 21, 19, 0.66) 58%, rgba(22, 21, 19, 0.2) 100%);
  }

  .home-final__content {
    display: grid;
    gap: 5rem;
    padding-block: 7rem 2rem;
  }

  .home-final__brand {
    display: grid;
    gap: 1.4rem;
  }

  .home-final__brand h2 {
    max-width: 900px;
    color: white;
    font-size: clamp(4rem, 7vw, 7rem);
    letter-spacing: -0.045em;
  }

  .home-final__brand > p:not(.eyebrow) {
    max-width: 650px;
    color: rgba(255, 255, 255, 0.7);
  }

  .home-creator {
    display: grid;
    grid-template-columns: minmax(250px, 0.75fr) minmax(300px, 1fr) auto;
    gap: 2rem;
    align-items: center;
