---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactForm from "@components/ContactForm.astro";
import { imageLibrary, siteConfig } from "@data/site";

const whatsappUrl = `https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent("Hola ClickMemories, quiero consultar disponibilidad para un proyecto.")}`;
---

<BaseLayout
  title="Contacto"
  description="Reserva una sesión, cobertura o proyecto audiovisual con ClickMemories."
  image={imageLibrary.production}
>
  <section class="page-hero contact-hero">
    <div class="container page-intro">
      <p class="eyebrow">Contacto</p>
      <h1>Hablemos de tu proyecto.</h1>
      <p>Cuéntanos qué quieres recordar o comunicar. Te responderemos con disponibilidad, próximos pasos y una propuesta clara.</p>
      <div class="category-list">
        <span class="pill">{siteConfig.availability}</span>
        <span class="pill">{siteConfig.responseTime}</span>
      </div>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container contact-experience">
      <aside class="contact-story" aria-label="Información para reservar">
        <div class="contact-story__media" aria-hidden="true">
          <img src={imageLibrary.production} alt="" width="900" height="1200" loading="lazy" />
        </div>
        <div class="contact-story__content">
          <p class="eyebrow">Reserva</p>
          <h2>Primero entendemos la historia. Después diseñamos cómo contarla.</h2>
          <p class="contact-story__copy">Cada propuesta parte de una conversación breve sobre intención, atmósfera y momentos importantes.</p>

          <div class="contact-story__signals" aria-label="Disponibilidad y respuesta">
            <div>
              <span>Agenda</span>
              <strong>2026 abierta</strong>
            </div>
            <div>
              <span>Respuesta</span>
              <strong>Menos de 24 h</strong>
            </div>
          </div>

          <div class="contact-story__channels">
            <p>¿Prefieres conversar directamente?</p>
            <a href={`mailto:${siteConfig.email}`}>
              <span>Correo</span>
              <strong>{siteConfig.email}</strong>
            </a>
            <a href={`tel:${siteConfig.phone.replaceAll(" ", "")}`}>
              <span>Teléfono</span>
              <strong>{siteConfig.phone}</strong>
            </a>
            <a class="button button--light" href={whatsappUrl} target="_blank" rel="noreferrer">Escribir por WhatsApp <span aria-hidden="true">↗</span></a>
          </div>
        </div>
      </aside>

      <div class="contact-form-shell" id="solicitud">
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
