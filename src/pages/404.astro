---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Página no encontrada" description="La página que buscas no existe o fue movida." noIndex>
  <section class="section">
    <div class="container page-intro">
      <p class="eyebrow">404</p>
      <h1>Esta historia no está en el archivo.</h1>
      <p>La página que buscas pudo cambiar de lugar. Puedes volver al inicio o explorar el portafolio.</p>
      <div class="section-actions" style="margin-top: 1.5rem;">
        <a class="button button--primary" href="/">Volver al inicio</a>
        <a class="button" href="/trabajos/">Ver trabajos</a>
      </div>
    </div>
  </section>
</BaseLayout>

