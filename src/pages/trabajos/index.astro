---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import PortfolioShowcase from "@components/PortfolioShowcase.astro";

const projects = (await getCollection("trabajos")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredProject = projects[0];
const portfolioProjects = projects.slice(1);
const featuredYear = featuredProject.data.date.getFullYear();
const ctaImage = projects.find((project) => project.id === "casa-nativa")?.data.cover ?? featuredProject.data.cover;
const completeCases = projects.filter((project) => project.data.projectType === "Caso completo").length;
const conceptCases = projects.length - completeCases;
---

<BaseLayout
  title="Trabajos"
  description="Portafolio de fotografía y video de ClickMemories para bodas, retratos, marcas, eventos y contenido social."
  image={featuredProject.data.cover}
>
  <section class="works-hero" aria-labelledby="works-title">
    <img
      src={featuredProject.data.cover}
      alt={featuredProject.data.coverAlt}
      width="1800"
      height="1200"
      loading="eager"
      fetchpriority="high"
      style={`view-transition-name: project-${featuredProject.id};`}
    />
    <div class="works-hero__veil"></div>
    <div class="container works-hero__content">
      <div class="works-hero__copy">
        <p class="eyebrow">Portafolio · Selección {featuredYear}</p>
        <h1 id="works-title">Historias que se sienten antes de explicarse.</h1>
        <p>Fotografía y video construidos desde la emoción, la luz y los detalles que hacen única cada historia.</p>
      </div>

      <a class="works-featured" href={`/trabajos/${featuredProject.id}/`}>
        <span class="works-featured__label">Proyecto destacado</span>
        <strong>{featuredProject.data.title}</strong>
        <span>{featuredProject.data.category} · {featuredProject.data.location}</span>
        <span class="works-featured__action">Ver historia <span aria-hidden="true">↗</span></span>
      </a>
    </div>
  </section>

  <section class="works-proof" aria-label="Alcance de la colección">
    <div class="container works-proof__grid">
      <p>
        <span>Una colección más amplia</span>
        Casos completos y conceptos transparentes para mostrar dirección, proceso y entrega.
      </p>
      <dl>
        <div><dt>{String(projects.length).padStart(2, "0")}</dt><dd>direcciones visuales</dd></div>
        <div><dt>{String(completeCases).padStart(2, "0")}</dt><dd>casos completos</dd></div>
        <div><dt>{String(conceptCases).padStart(2, "0")}</dt><dd>proyectos conceptuales</dd></div>
        <div><dt>Foto + film</dt><dd>formatos combinados</dd></div>
      </dl>
    </div>
  </section>

  <section class="section works-collection" aria-labelledby="works-collection-title">
    <div class="container">
      <PortfolioShowcase projects={portfolioProjects} headingId="works-collection-title" />
    </div>
  </section>

  <section class="works-cta" aria-labelledby="works-cta-title">
    <img src={ctaImage} alt="" width="1800" height="1200" loading="lazy" />
    <div class="container works-cta__content">
      <p class="eyebrow">La próxima historia</p>
      <h2 id="works-cta-title">La imagen correcta no solo muestra. Hace sentir.</h2>
      <p>Cuéntanos qué quieres conservar o comunicar y diseñaremos una propuesta visual alrededor de tu historia.</p>
      <div class="section-actions">
        <a class="button button--light" href="/contacto/">Ver disponibilidad</a>
        <a class="works-cta__link" href="/servicios/">Explorar servicios <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
