---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import WorkGallery from "@components/WorkGallery.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { siteConfig } from "@data/site";

export async function getStaticPaths() {
  const projects = await getCollection("trabajos");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const related = (await getCollection("trabajos"))
  .filter((item) => item.id !== project.id)
  .slice(0, 3);
const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.data.title,
  description: project.data.excerpt,
  image: new URL(project.data.cover, siteConfig.url).toString(),
  dateCreated: project.data.date.toISOString(),
  genre: project.data.category,
  keywords: [...project.data.mood, ...project.data.services].join(", "),
  contentLocation: project.data.location,
  creator: { "@id": `${siteConfig.url}/#organization` }
};
---

<BaseLayout
  title={project.data.title}
  description={project.data.excerpt}
  image={project.data.cover}
  type="article"
  structuredData={projectSchema}
>
  <article>
    <header class="detail-hero">
      <img
        src={project.data.cover}
        alt={project.data.coverAlt}
        width="1800"
        height="1200"
        style={`view-transition-name: project-${project.id};`}
      />
      <div class="detail-hero__content">
        <div class="detail-meta">
          <span>{project.data.projectType}</span>
          <span>{project.data.category}</span>
          <span>{project.data.location}</span>
          <span>{project.data.duration}</span>
        </div>
        <h1>{project.data.title}</h1>
        <p>{project.data.excerpt}</p>
      </div>
    </header>

    <section class="section project-summary">
      <div class="container detail-grid">
        <div>
          <SectionHeading
            eyebrow="Resumen visual"
            title="Una lectura rápida del proyecto."
            description="Antes de entrar a la galería completa, estos son los elementos que definieron la cobertura y el tono de la entrega."
          />
          <div class="category-list">
            {project.data.mood.map((mood) => <span class="pill">{mood}</span>)}
          </div>
        </div>
        <aside class="info-panel" aria-label="Resumen del proyecto">
          <h2>Detalles</h2>
          <ul class="sidebar-list">
            <li><strong>Categoría</strong><span>{project.data.category}</span></li>
            <li><strong>Ubicación</strong><span>{project.data.location}</span></li>
            <li><strong>Duración</strong><span>{project.data.duration}</span></li>
          </ul>
          <h2 style="margin-top: 1.5rem;">Servicios</h2>
          <div class="category-list">
            {project.data.services.map((service) => <span class="pill">{service}</span>)}
          </div>
        </aside>
      </div>
    </section>

    <WorkGallery title={project.data.title} items={project.data.gallery} video={project.data.video} />

    <section class="section">
      <div class="container detail-grid">
        <div class="prose">
          <Content />
        </div>
        <aside class="info-panel project-quote" aria-label="Testimonio del cliente">
          {
            project.data.testimonial ? (
              <figure>
                <blockquote>“{project.data.testimonial.quote}”</blockquote>
                <figcaption>
                  <strong>{project.data.testimonial.author}</strong>
                  <span>{project.data.testimonial.context}</span>
                </figcaption>
              </figure>
            ) : (
              <div>
                <p class="eyebrow">Proyecto conceptual</p>
                <p>Esta dirección visual muestra una posibilidad creativa y su alcance sin atribuir resultados ni comentarios a un cliente real.</p>
              </div>
            )
          }
        </aside>
      </div>
    </section>

    <section class="section section--dark">
      <div class="container">
        <SectionHeading
          eyebrow="Reserva"
          title="¿Quieres una historia con esta mirada?"
          description="Podemos adaptar el ritmo, los formatos y la cobertura a tu fecha, campaña o sesión."
        />
        <div class="cta-actions">
          <a class="button button--light" href="/contacto/">Quiero una historia así</a>
          <a class="button button--secondary" href="/servicios/">Ver servicios</a>
        </div>
      </div>
    </section>
  </article>

  <section class="section section--cream">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Más historias</p>
        <h2>Otros trabajos de ClickMemories.</h2>
      </div>
      <div class="project-grid">
        {related.map((item) => <ProjectCard project={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
