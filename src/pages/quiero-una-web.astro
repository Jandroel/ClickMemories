---
import BaseLayout from "@layouts/BaseLayout.astro";
import LiveResponsivePreview from "@components/LiveResponsivePreview.astro";
import { developerProfile, imageLibrary } from "@data/site";

const developerMessage = "Hola Jandroel, vi el caso ClickMemories y quisiera conversar sobre una página web.";
const developerWhatsappUrl = `https://wa.me/${developerProfile.whatsapp}?text=${encodeURIComponent(developerMessage)}`;
const developerEmailUrl = `mailto:${developerProfile.email}?subject=${encodeURIComponent("Consulta por diseño y desarrollo web")}&body=${encodeURIComponent(developerMessage)}`;
const professionalSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: developerProfile.name,
    jobTitle: developerProfile.role,
    email: developerProfile.email,
    address: {
      "@type": "PostalAddress",
      addressLocality: developerProfile.location,
      addressCountry: "PE"
    },
    sameAs: [developerProfile.githubUrl]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Diseño y desarrollo web a medida",
    description: "Landing pages, sitios comerciales y portafolios responsive con estrategia, dirección visual y desarrollo frontend.",
    provider: {
      "@type": "Person",
      name: developerProfile.name
    },
    areaServed: "Perú"
  }
];

const deliverables = [
  {
    title: "Estrategia y contenido",
    text: "Ordenamos el mensaje, las prioridades y el recorrido antes de diseñar pantallas."
  },
  {
    title: "Dirección visual",
    text: "Construimos tipografía, color, composición y movimiento alrededor de la personalidad del negocio."
  },
  {
    title: "Desarrollo responsive",
    text: "La experiencia se diseña para escritorio, tablet y móvil con interacciones accesibles."
  },
  {
    title: "Base preparada para crecer",
    text: "SEO técnico, contenido organizado, validaciones y una estructura fácil de mantener."
  }
];

const projectTypes = [
  {
    label: "Una idea, una acción",
    title: "Landing page",
    text: "Para presentar una campaña, producto o servicio con un objetivo de conversión claro."
  },
  {
    label: "Una marca, varios servicios",
    title: "Sitio comercial",
    text: "Para negocios que necesitan explicar mejor su oferta, generar confianza y recibir consultas."
  },
  {
    label: "Trabajo que debe verse",
    title: "Portafolio editorial",
    text: "Para profesionales creativos, estudios y marcas donde los casos son parte central de la venta."
  }
];

const process = [
  { title: "Entender", text: "Objetivo, público, contenido y referencias." },
  { title: "Diseñar", text: "Jerarquía, dirección visual y prototipo responsive." },
  { title: "Construir", text: "Desarrollo, contenido, movimiento y estados." },
  { title: "Pulir", text: "Pruebas, accesibilidad, rendimiento y entrega." }
];
---

<BaseLayout
  title="Quiero una web así"
  description="Diseño y desarrollo de landing pages, sitios comerciales y portafolios digitales con una experiencia visual a medida."
  image={imageLibrary.production}
  structuredData={professionalSchema}
>
  <section class="web-hero">
    <div class="container web-hero__grid">
      <div class="web-hero__copy">
        <p class="eyebrow">Diseño y desarrollo · {developerProfile.name}</p>
        <h1>Una web debería hacer más claro por qué elegirte.</h1>
        <p>Diseño experiencias digitales para negocios y profesionales que necesitan presentar mejor su trabajo, diferenciarse y convertir interés en conversaciones reales.</p>
        <div class="hero__actions">
          <a class="button button--light" href="#vista-en-vivo">Explorar el resultado</a>
          <a class="button button--secondary" href={developerWhatsappUrl} target="_blank" rel="noreferrer" data-analytics="web_lead_opened">Hablemos de tu proyecto <span aria-hidden="true">↗</span></a>
        </div>

        <dl class="web-hero__signals">
          <div><dt>Enfoque</dt><dd>Diseño a medida</dd></div>
          <div><dt>Experiencia</dt><dd>Responsive real</dd></div>
          <div><dt>Entrega</dt><dd>Base mantenible</dd></div>
        </dl>
      </div>

      <div class="web-hero__showcase" aria-label="Composición responsive de ClickMemories">
        <div class="web-hero__desktop">
          <div class="web-hero__bar"><span></span><span></span><span></span><small>ClickMemories</small></div>
          <img src={imageLibrary.wedding} alt="Portada de ClickMemories mostrada en una pantalla de escritorio." width="1200" height="900" loading="eager" />
          <div class="web-hero__screen-copy"><small>Fotografía + Film</small><strong>Historias que vuelven a sentirse.</strong></div>
        </div>
        <div class="web-hero__phone">
          <div class="web-hero__phone-speaker"></div>
          <img src={imageLibrary.weddingVeil} alt="Vista móvil de una historia visual de ClickMemories." width="600" height="900" loading="eager" />
          <strong>Responsive<br />por diseño</strong>
        </div>
        <span class="web-hero__note">Estrategia · Diseño · Código</span>
      </div>
    </div>
  </section>

  <section class="section web-case" aria-labelledby="web-case-title">
    <div class="container web-case__grid" data-reveal>
      <div>
        <p class="eyebrow">El caso ClickMemories</p>
        <h2 id="web-case-title">No empezó eligiendo colores. Empezó entendiendo qué debía transmitir.</h2>
      </div>
      <div class="web-case__copy">
        <p class="web-case__lead">La marca necesitaba sentirse emocional y cinematográfica, pero también clara al presentar trabajos, servicios y formas de contacto.</p>
        <p>La solución combina una narrativa visual fuerte con filtros de portafolio, exploradores de servicio, formularios guiados y una estructura adaptable a distintos tipos de contenido.</p>
        <ul>
          <li><span>Contenido</span><strong>Organizado y reutilizable</strong></li>
          <li><span>Interacciones</span><strong>Accesibles por teclado</strong></li>
          <li><span>Calidad</span><strong>Validada automáticamente</strong></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section web-preview" id="vista-en-vivo" aria-labelledby="web-preview-title">
    <div class="container">
      <header class="web-section-heading" data-reveal>
        <div>
          <p class="eyebrow">Responsive en vivo</p>
          <h2 id="web-preview-title">La misma identidad. Una composición pensada para cada pantalla.</h2>
        </div>
        <p>Cambia el tamaño de la vista y observa cómo el contenido reorganiza jerarquías, imágenes y acciones sin perder personalidad.</p>
      </header>
      <LiveResponsivePreview />
    </div>
  </section>

  <section class="section web-deliverables" aria-labelledby="web-deliverables-title">
    <div class="container web-deliverables__grid">
      <div class="web-deliverables__intro">
        <p class="eyebrow">Lo que construimos</p>
        <h2 id="web-deliverables-title">Una experiencia completa, no una colección de pantallas.</h2>
        <p>Cada decisión visual tiene una responsabilidad comercial y cada interacción debe ayudar al usuario a avanzar.</p>
      </div>
      <div class="web-deliverables__list" data-reveal>
        {
          deliverables.map((item, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section web-solutions" aria-labelledby="web-solutions-title">
    <div class="container">
      <header class="web-section-heading web-section-heading--dark" data-reveal>
        <div>
          <p class="eyebrow">El alcance correcto</p>
          <h2 id="web-solutions-title">No todos los proyectos necesitan el mismo tipo de web.</h2>
        </div>
        <p>Elegimos el alcance según lo que el negocio necesita explicar, mostrar y conseguir.</p>
      </header>

      <div class="web-solutions__grid" data-reveal>
        {
          projectTypes.map((item, index) => (
            <article>
              <header><span>{String(index + 1).padStart(2, "0")}</span><small>{item.label}</small></header>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section web-process" aria-labelledby="web-process-title">
    <div class="container">
      <header class="web-process__heading" data-reveal>
        <div><p class="eyebrow">Cómo trabajamos</p><h2 id="web-process-title">Un proceso visible de principio a fin.</h2></div>
        <p>La comunicación y los siguientes pasos se mantienen claros durante todo el proyecto.</p>
      </header>
      <ol class="web-process__steps" data-reveal>
        {process.map((item, index) => <li><span>{String(index + 1).padStart(2, "0")}</span><h3>{item.title}</h3><p>{item.text}</p></li>)}
      </ol>
    </div>
  </section>

  <section class="section web-profile" id="desarrollador" aria-labelledby="web-profile-title">
    <div class="container web-profile__grid" data-reveal>
      <aside class="web-profile__card" aria-label={`Perfil profesional de ${developerProfile.name}`}>
        <div class="web-profile__monogram" aria-hidden="true">
          <span>J</span>
          <i></i>
        </div>
        <div class="web-profile__card-copy">
          <span>Diseño + desarrollo</span>
          <strong>{developerProfile.name}</strong>
          <small>{developerProfile.location}</small>
        </div>
        <div class="web-profile__status"><i></i> Disponible para nuevos proyectos</div>
      </aside>

      <div class="web-profile__content">
        <p class="eyebrow">La persona detrás del proyecto</p>
        <h2 id="web-profile-title">Hola, soy {developerProfile.name}. Diseño la idea y también construyo el producto.</h2>
        <p class="web-profile__lead">{developerProfile.bio}</p>
        <ul>
          {developerProfile.strengths.map((strength) => <li><span aria-hidden="true">↗</span>{strength}</li>)}
        </ul>
        <div class="web-profile__actions">
          <a class="button button--primary" href={developerWhatsappUrl} target="_blank" rel="noreferrer" data-analytics="web_lead_opened">Contarme tu idea <span aria-hidden="true">↗</span></a>
          <a class="web-profile__link" href={developerEmailUrl}>Escribir por correo</a>
          <a class="web-profile__link" href={developerProfile.githubUrl} target="_blank" rel="noreferrer">Ver GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <section class="web-cta">
    <img src={imageLibrary.production} alt="Cámara profesional durante una producción visual." width="1800" height="1200" loading="lazy" />
    <div class="container web-cta__content">
      <p class="eyebrow">Tu proyecto puede ser el siguiente</p>
      <h2>Si tu trabajo ya es bueno, hagamos que presentarlo esté a la misma altura.</h2>
      <p>Cuéntame qué haces, qué necesitas mostrar y qué debería conseguir tu nueva web.</p>
      <div class="cta-actions">
        <a class="button button--light" href={developerWhatsappUrl} target="_blank" rel="noreferrer" data-analytics="web_lead_opened">Hablemos de tu proyecto <span aria-hidden="true">↗</span></a>
        <a class="button button--secondary" href={developerProfile.sourceUrl} target="_blank" rel="noreferrer">Revisar el código</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .web-hero {
    overflow: hidden;
    background: var(--color-ink);
    color: white;
  }

  .web-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(470px, 1.1fr);
    gap: clamp(3rem, 7vw, 7rem);
    min-height: calc(100svh - 72px);
    align-items: center;
    padding-block: clamp(4.5rem, 8vw, 7rem);
  }

  .web-hero__copy {
    display: grid;
    gap: 1.4rem;
    position: relative;
    z-index: 2;
  }

  .web-hero .eyebrow,
  .web-cta .eyebrow {
    color: var(--color-gold);
  }

  .web-hero h1 {
    max-width: 760px;
    color: white;
    font-size: clamp(4rem, 6.5vw, 6.6rem);
  }

  .web-hero__copy > p:not(.eyebrow) {
    max-width: 610px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.05rem;
  }

  .web-hero__signals {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 2.2rem;
    border-top: 1px solid var(--color-line-inverse);
  }

  .web-hero__signals div {
    display: grid;
    gap: 0.15rem;
    padding: 1rem 0.7rem 0 0;
  }

  .web-hero__signals dt,
  .web-hero__signals dd {
    margin: 0;
  }

  .web-hero__signals dt {
    color: rgba(255, 255, 255, 0.46);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .web-hero__signals dd {
    color: white;
    font-size: 0.82rem;
    font-weight: 750;
  }

  .web-hero__showcase {
    position: relative;
    min-height: 690px;
  }

  .web-hero__desktop {
    position: absolute;
    inset: 2rem 0 3.5rem 2rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: var(--color-paper);
    box-shadow: 0 35px 100px rgba(0, 0, 0, 0.35);
    animation: web-screen-enter var(--duration-narrative) var(--ease-out) both;
  }

  .web-hero__bar {
    display: flex;
    gap: 0.35rem;
    align-items: center;
    height: 34px;
    padding-inline: 0.7rem;
    background: white;
  }

  .web-hero__bar span {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: var(--radius-round);
    background: rgba(22, 21, 19, 0.2);
  }

  .web-hero__bar small {
    margin-inline: auto;
    color: var(--color-muted);
    font-size: 0.58rem;
  }

  .web-hero__desktop > img {
    width: 100%;
    height: calc(100% - 34px);
    object-fit: cover;
  }

  .web-hero__desktop::after {
    content: "";
    position: absolute;
    inset: 34px 0 0;
    background: linear-gradient(0deg, rgba(22, 21, 19, 0.82), rgba(22, 21, 19, 0.08) 60%);
  }

  .web-hero__screen-copy {
    position: absolute;
    right: 2rem;
    bottom: 2rem;
    left: 2rem;
    z-index: 1;
    display: grid;
    gap: 0.3rem;
  }

  .web-hero__screen-copy small {
    color: var(--color-gold);
    font-size: 0.64rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .web-hero__screen-copy strong {
    max-width: 560px;
    color: white;
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 400;
    line-height: 1;
  }

  .web-hero__phone {
    position: absolute;
    right: -1rem;
    bottom: 0;
    z-index: 2;
    width: 31%;
    aspect-ratio: 9 / 18;
    overflow: hidden;
    border: 7px solid #2b2925;
    border-radius: 30px;
    background: var(--color-ink-soft);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.4);
    animation: web-phone-enter var(--duration-narrative) 140ms var(--ease-out) both;
  }

  .web-hero__phone::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(22, 21, 19, 0.78), transparent 62%);
  }

  .web-hero__phone img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .web-hero__phone strong {
    position: absolute;
    right: 1rem;
    bottom: 1.2rem;
    left: 1rem;
    z-index: 1;
    color: white;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1;
  }

  .web-hero__phone-speaker {
    position: absolute;
    top: 0.45rem;
    left: 50%;
    z-index: 3;
    width: 32%;
    height: 0.32rem;
    border-radius: var(--radius-pill);
    transform: translateX(-50%);
    background: #2b2925;
  }

  .web-hero__note {
    position: absolute;
    bottom: 0.2rem;
    left: 0;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
  }

  .web-case__grid,
  .web-deliverables__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.75fr);
    gap: clamp(3rem, 9vw, 9rem);
    align-items: start;
  }

  .web-case h2,
  .web-section-heading h2,
  .web-deliverables h2,
  .web-process__heading h2 {
    font-size: clamp(3.3rem, 6vw, 6rem);
  }

  .web-case__copy {
    display: grid;
    gap: 1.3rem;
    border-top: 1px solid var(--color-line-strong);
    padding-top: 1.5rem;
  }

  .web-case__lead {
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 1.8rem;
    line-height: 1.25;
  }

  .web-case__copy ul {
    margin-top: 1rem;
    border-top: 1px solid var(--color-line);
  }

  .web-case__copy li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--color-line);
    padding: 0.9rem 0;
    font-size: 0.78rem;
  }

  .web-case__copy li span { color: var(--color-muted); }

  .web-preview {
    scroll-margin-top: 5rem;
    background: var(--color-cream);
  }

  .web-section-heading,
  .web-process__heading {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.55fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .web-section-heading > p,
  .web-process__heading > p {
    border-left: 1px solid var(--color-line-strong);
    padding-left: 1.3rem;
  }

  .web-deliverables__intro {
    position: sticky;
    top: 7rem;
  }

  .web-deliverables__intro > p:last-child {
    max-width: 560px;
    margin-top: 1.2rem;
  }

  .web-deliverables__list {
    border-top: 1px solid var(--color-line-strong);
  }

  .web-deliverables__list article {
    display: grid;
    grid-template-columns: 3rem minmax(180px, 0.65fr) 1fr;
    gap: 1.3rem;
    border-bottom: 1px solid var(--color-line);
    padding: 1.8rem 0;
  }

  .web-deliverables__list article > span {
    color: var(--color-clay);
    font-family: var(--font-serif);
    font-size: 1.3rem;
  }

  .web-deliverables__list h3,
  .web-solutions__grid h3,
  .web-process__steps h3 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
  }

  .web-solutions {
    background: var(--color-ink);
    color: white;
  }

  .web-section-heading--dark h2,
  .web-section-heading--dark > p {
    color: white;
  }

  .web-section-heading--dark .eyebrow { color: var(--color-gold); }
  .web-section-heading--dark > p { border-color: var(--color-line-inverse); color: rgba(255, 255, 255, 0.62); }

  .web-solutions__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-line-inverse);
  }

  .web-solutions__grid article {
    display: grid;
    align-content: start;
    gap: 1.2rem;
    min-height: 400px;
    border-right: 1px solid var(--color-line-inverse);
    padding: 1.5rem 2rem 2rem 0;
  }

  .web-solutions__grid article + article { padding-left: 2rem; }
  .web-solutions__grid article:last-child { border-right: 0; }

  .web-solutions__grid header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
  }

  .web-solutions__grid header span {
    color: var(--color-gold);
    font-family: var(--font-serif);
    font-size: 1.6rem;
  }

  .web-solutions__grid header small {
    color: rgba(255, 255, 255, 0.42);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .web-solutions__grid h3 { color: white; font-size: 3rem; }
  .web-solutions__grid p { color: rgba(255, 255, 255, 0.62); }

  .web-process__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--color-line-strong);
  }

  .web-process__steps li {
    min-height: 260px;
    border-right: 1px solid var(--color-line);
    padding: 1.5rem 1.5rem 0 0;
  }

  .web-process__steps li + li { padding-left: 1.5rem; }
  .web-process__steps li:last-child { border-right: 0; }
  .web-process__steps li > span { display: block; margin-bottom: 2.5rem; color: var(--color-clay); font-family: var(--font-serif); font-size: 1.4rem; }
  .web-process__steps h3 { margin-bottom: 0.6rem; }

  .web-profile {
    overflow: hidden;
    background: var(--color-cream);
  }

  .web-profile__grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(3rem, 8vw, 8rem);
    align-items: center;
  }

  .web-profile__card {
    position: relative;
    display: grid;
    min-height: 560px;
    align-content: space-between;
    overflow: hidden;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background:
      radial-gradient(circle at 78% 18%, rgba(217, 164, 65, 0.22), transparent 28%),
      var(--color-ink);
    color: white;
    isolation: isolate;
  }

  .web-profile__card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.3;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.12) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(135deg, black, transparent 72%);
  }

  .web-profile__monogram {
    position: relative;
    display: grid;
    width: min(78%, 320px);
    aspect-ratio: 1;
    place-items: center;
    justify-self: center;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 50%;
  }

  .web-profile__monogram::before,
  .web-profile__monogram::after {
    content: "";
    position: absolute;
    background: rgba(255, 255, 255, 0.2);
  }

  .web-profile__monogram::before {
    width: 145%;
    height: 1px;
  }

  .web-profile__monogram::after {
    width: 1px;
    height: 145%;
  }

