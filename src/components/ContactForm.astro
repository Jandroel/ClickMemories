---
import { budgetRanges, contactOptions, siteConfig } from "@data/site";

const today = new Date().toISOString().slice(0, 10);
---

<form
  class="contact-form"
  data-contact-form
  data-contact-email={siteConfig.email}
  data-contact-whatsapp={siteConfig.whatsapp}
  novalidate
>
  <header class="contact-form__intro">
    <div class="contact-form__intro-top">
      <p class="eyebrow">Solicitud de proyecto</p>
      <span data-step-count>Paso 1 de 3</span>
    </div>
    <h2>Cuéntanos lo esencial.</h2>
    <p>En tres pasos reunimos lo necesario y preparamos tu mensaje para enviarlo por el canal que prefieras.</p>
  </header>

  <nav class="form-progress" aria-label="Progreso de la solicitud" data-form-progress>
    <ol>
      <li class="is-active" data-progress-item aria-current="step">
        <span>01</span>
        <strong>Tus datos</strong>
      </li>
      <li data-progress-item>
        <span>02</span>
        <strong>El proyecto</strong>
      </li>
      <li data-progress-item>
        <span>03</span>
        <strong>La idea</strong>
      </li>
    </ol>
    <div class="form-progress__track" aria-hidden="true"><span data-progress-bar></span></div>
  </nav>

  <label class="form-trap" aria-hidden="true">
    <span>No completar este campo</span>
    <input name="empresa_web" type="text" tabindex="-1" autocomplete="off" data-honeypot />
  </label>

  <div class="form-steps" data-form-steps>
    <section class="form-section" data-form-step data-step="0" aria-labelledby="form-step-person">
      <div class="form-section__heading">
        <h3 id="form-step-person" tabindex="-1">Empecemos por ti</h3>
        <p>Lo necesario para poder responderte de forma directa.</p>
      </div>
      <div class="form-grid">
        <label class="form-field">
          <span>Nombre</span>
          <input
            name="nombre"
            type="text"
            autocomplete="name"
            minlength="2"
            maxlength="80"
            required
            data-field
            data-message="Ingresa tu nombre."
          />
          <small class="field-error" aria-live="polite"></small>
        </label>
        <label class="form-field">
          <span>Correo electrónico</span>
          <input
            name="correo"
            type="email"
            autocomplete="email"
            maxlength="120"
            required
            data-field
            data-message="Ingresa un correo válido."
          />
          <small class="field-error" aria-live="polite"></small>
        </label>
      </div>
      <div class="form-step-actions form-step-actions--end">
        <button class="button button--primary" type="button" data-next>
          Continuar <span aria-hidden="true">→</span>
        </button>
      </div>
    </section>

    <section class="form-section" data-form-step data-step="1" aria-labelledby="form-step-project" hidden aria-hidden="true">
      <div class="form-section__heading">
        <h3 id="form-step-project" tabindex="-1">¿Qué vamos a crear?</h3>
        <p>Selecciona el punto de partida y añade el contexto principal.</p>
      </div>

      <fieldset class="form-option-group" data-service-group aria-describedby="service-hint service-error">
        <legend>Tipo de servicio</legend>
        <div class="option-grid option-grid--services">
          {
            contactOptions.map((option) => (
              <label class="option-card">
                <input type="radio" name="servicio" value={option} required />
                <span>{option}</span>
              </label>
            ))
          }
        </div>
        <small class="service-hint" id="service-hint" data-service-hint>Elige una opción para personalizar las siguientes preguntas.</small>
        <small class="field-error" id="service-error" data-service-error aria-live="polite"></small>
      </fieldset>

      <div class="form-grid">
        <label class="form-field">
          <span>Fecha del evento o proyecto <small>Opcional</small></span>
          <input name="fecha" type="date" min={today} data-field />
          <small class="field-error" aria-live="polite"></small>
        </label>
        <label class="form-field">
          <span>Ubicación <small>Opcional</small></span>
          <input
            name="ubicacion"
            type="text"
            autocomplete="address-level2"
            maxlength="120"
            placeholder="Ciudad o locación"
            data-field
          />
          <small class="field-error" aria-live="polite"></small>
        </label>
      </div>

      <div class="form-step-actions">
        <button class="form-back" type="button" data-back><span aria-hidden="true">←</span> Volver</button>
        <button class="button button--primary" type="button" data-next>
          Continuar <span aria-hidden="true">→</span>
        </button>
      </div>
    </section>

    <section class="form-section" data-form-step data-step="2" aria-labelledby="form-step-idea" hidden aria-hidden="true">
      <div class="form-section__heading">
        <h3 id="form-step-idea" tabindex="-1">Cuéntanos la idea</h3>
        <p>Una referencia de inversión y el corazón de lo que imaginas.</p>
      </div>

      <fieldset class="form-option-group form-option-group--budget">
        <legend>Rango de presupuesto <small>Opcional</small></legend>
        <div class="option-grid">
          {
            budgetRanges.map((range) => (
              <label class="option-card">
                <input type="radio" name="presupuesto" value={range} />
                <span>{range}</span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <label class="form-field form-field--message">
        <span>¿Qué debería lograr o hacer sentir?</span>
        <textarea
          name="mensaje"
          rows="5"
          minlength="12"
          maxlength="1600"
          required
          data-field
          data-message="Cuéntanos un poco más sobre tu proyecto."
          placeholder="Comparte la intención, referencias y cualquier detalle que nos ayude a imaginarlo contigo."
        ></textarea>
        <small class="field-error" aria-live="polite"></small>
      </label>

      <label class="form-consent">
        <input
          name="privacidad"
          type="checkbox"
          required
          data-field
          data-message="Necesitamos tu autorización para preparar la solicitud."
        />
        <span>
          Acepto que mis datos se usen para responder esta solicitud. He leído la
          <a href="/privacidad/" target="_blank" rel="noreferrer">política de privacidad</a>.
        </span>
        <small class="field-error" aria-live="polite"></small>
      </label>

      <div class="form-step-actions">
        <button class="form-back" type="button" data-back><span aria-hidden="true">←</span> Volver</button>
        <button class="button button--primary" type="submit">
          Preparar mi solicitud <span aria-hidden="true">→</span>
        </button>
      </div>
      <p class="form-assurance"><span aria-hidden="true">✓</span> Tú eliges el canal antes de enviar. No guardamos datos en esta web.</p>
    </section>
  </div>

  <section class="form-complete" data-form-complete hidden aria-labelledby="form-complete-title" tabindex="-1">
    <div class="form-complete__icon" aria-hidden="true">✓</div>
    <p class="eyebrow">Solicitud preparada</p>
    <h3 id="form-complete-title">Ya puedes enviarla.</h3>
    <p>Revisa el resumen y elige WhatsApp o correo. Abriremos el mensaje completo para que puedas editarlo antes de enviarlo.</p>
    <dl class="form-review">
      <div><dt>Nombre</dt><dd data-review-name></dd></div>
      <div><dt>Servicio</dt><dd data-review-service></dd></div>
      <div><dt>Fecha</dt><dd data-review-date></dd></div>
      <div><dt>Inversión</dt><dd data-review-budget></dd></div>
    </dl>
    <div class="form-complete__actions">
      <a class="button button--primary" href="#" target="_blank" rel="noreferrer" data-submit-whatsapp>
        Enviar por WhatsApp <span aria-hidden="true">↗</span>
      </a>
      <a class="button button--secondary" href="#" data-submit-email>
        Enviar por correo <span aria-hidden="true">→</span>
      </a>
    </div>
    <button class="form-edit" type="button" data-edit-request><span aria-hidden="true">←</span> Editar información</button>
  </section>

  <p class="form-status" data-form-status aria-live="polite"></p>
</form>

<script>
  const form = document.querySelector("[data-contact-form]");

  if (form instanceof HTMLFormElement) {
    const steps = Array.from(form.querySelectorAll<HTMLElement>("[data-form-step]"));
    const progressItems = Array.from(form.querySelectorAll<HTMLElement>("[data-progress-item]"));
    const nextButtons = Array.from(form.querySelectorAll<HTMLButtonElement>("[data-next]"));
    const backButtons = Array.from(form.querySelectorAll<HTMLButtonElement>("[data-back]"));
    const stepCount = form.querySelector<HTMLElement>("[data-step-count]");
    const progressBar = form.querySelector<HTMLElement>("[data-progress-bar]");
    const progress = form.querySelector<HTMLElement>("[data-form-progress]");
    const formSteps = form.querySelector<HTMLElement>("[data-form-steps]");
    const complete = form.querySelector<HTMLElement>("[data-form-complete]");
    const editButton = form.querySelector<HTMLButtonElement>("[data-edit-request]");
    const fields = Array.from(form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("[data-field]"));
    const serviceInputs = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="servicio"]'));
    const serviceGroup = form.querySelector<HTMLElement>("[data-service-group]");
    const serviceError = form.querySelector<HTMLElement>("[data-service-error]");
    const serviceHint = form.querySelector<HTMLElement>("[data-service-hint]");
    const honeypot = form.querySelector<HTMLInputElement>("[data-honeypot]");
    const status = form.querySelector<HTMLElement>("[data-form-status]");
    const whatsappLink = form.querySelector<HTMLAnchorElement>("[data-submit-whatsapp]");
    const emailLink = form.querySelector<HTMLAnchorElement>("[data-submit-email]");
    let currentStep = 0;
    let interactionTracked = false;

    const track = (name: string, props: Record<string, string> = {}) => {
      window.dispatchEvent(new CustomEvent("cm:analytics", { detail: { name, props } }));
    };

    const serviceHints: Record<string, string> = {
      "Film de boda": "Incluye fecha, locación, invitados aproximados y los momentos que no pueden faltar.",
      "Fotografía de eventos": "Cuéntanos horario, tipo de evento, asistentes y entregables esperados.",
      "Video para marcas": "Comparte objetivo de campaña, canales de publicación y referencias visuales.",
      "Sesión de retrato": "Indica si buscas una imagen personal, editorial, de prensa o para redes.",
      "Reels para redes sociales": "Cuéntanos cuántas piezas necesitas, duración y estilo de edición.",
      "Cobertura completa": "Describe la jornada para estimar equipo, tiempos y entregables.",
      "Edición y postproducción": "Indica el material existente, duración final y fecha límite."
    };

    const showError = (field: HTMLInputElement | HTMLTextAreaElement) => {
      const wrapper = field.closest("label");
      const error = wrapper?.querySelector<HTMLElement>(".field-error");
      const message = field.dataset.message ?? "";

      if (!field.validity.valid) {
        if (error) error.textContent = message;
        field.setAttribute("aria-invalid", "true");
        return false;
      }

      if (error) error.textContent = "";
      field.removeAttribute("aria-invalid");
      return true;
    };

    const validateService = () => {
      const selected = serviceInputs.find((input) => input.checked);
      if (!selected) {
        if (serviceError) serviceError.textContent = "Selecciona un tipo de servicio.";
        serviceGroup?.setAttribute("aria-invalid", "true");
        return false;
      }

      if (serviceError) serviceError.textContent = "";
      serviceGroup?.removeAttribute("aria-invalid");
      return true;
    };

    const validateStep = (index: number) => {
      const step = steps[index];
      if (!step) return false;
      const stepFields = Array.from(step.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("[data-field]"));
      const fieldsAreValid = stepFields.map((field) => showError(field)).every(Boolean);
      const serviceIsValid = index === 1 ? validateService() : true;
      return fieldsAreValid && serviceIsValid;
    };

    const showStep = (index: number, moveFocus = true) => {
      currentStep = Math.max(0, Math.min(index, steps.length - 1));
      form.classList.remove("is-complete");
      if (complete) complete.hidden = true;
      if (progress) progress.hidden = false;
      if (formSteps) formSteps.hidden = false;

      steps.forEach((step, stepIndex) => {
        const isCurrent = stepIndex === currentStep;
        step.hidden = !isCurrent;
        step.setAttribute("aria-hidden", String(!isCurrent));
      });

      progressItems.forEach((item, itemIndex) => {
        item.classList.toggle("is-active", itemIndex === currentStep);
        item.classList.toggle("is-complete", itemIndex < currentStep);
        if (itemIndex === currentStep) item.setAttribute("aria-current", "step");
        else item.removeAttribute("aria-current");
      });

      if (stepCount) stepCount.textContent = `Paso ${currentStep + 1} de ${steps.length}`;
      if (progressBar) progressBar.style.width = `${(currentStep / (steps.length - 1)) * 100}%`;
      if (status) status.textContent = "";

      if (moveFocus) {
        window.requestAnimationFrame(() => steps[currentStep]?.querySelector<HTMLElement>("h3")?.focus());
      }
    };

    const continueToNextStep = () => {
      if (validateStep(currentStep)) {
        showStep(currentStep + 1);
        track("contact_step_view", { step: String(currentStep + 1) });
      } else if (status) {
        status.textContent = "Completa los campos de este paso antes de continuar.";
      }
    };

    const readValue = (data: FormData, key: string, fallback = "Por definir") => {
      const value = data.get(key);
      return typeof value === "string" && value.trim() ? value.trim() : fallback;
    };

    const formatDate = (value: string) => {
      if (value === "Por definir") return value;
      const parsed = new Date(`${value}T12:00:00`);
      return Number.isNaN(parsed.valueOf())
        ? value
        : new Intl.DateTimeFormat("es-PE", { day: "numeric", month: "long", year: "numeric" }).format(parsed);
    };

    const prepareRequest = () => {
      const data = new FormData(form);
      const name = readValue(data, "nombre");
      const email = readValue(data, "correo");
      const service = readValue(data, "servicio");
      const date = formatDate(readValue(data, "fecha"));
      const location = readValue(data, "ubicacion");
      const budget = readValue(data, "presupuesto");
      const message = readValue(data, "mensaje");
      const body = [
        "Hola ClickMemories, quiero consultar por un proyecto.",
        "",
        `Nombre: ${name}`,
        `Correo: ${email}`,
        `Servicio: ${service}`,
        `Fecha: ${date}`,
        `Ubicación: ${location}`,
        `Presupuesto: ${budget}`,
        "",
        "Idea y objetivo:",
        message
      ].join("\n");
      const subject = `Solicitud de ${service} — ${name}`;

      if (whatsappLink) {
        whatsappLink.href = `https://wa.me/${form.dataset.contactWhatsapp}?text=${encodeURIComponent(body)}`;
      }
      if (emailLink) {
        emailLink.href = `mailto:${form.dataset.contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      }

      const reviewValues: Record<string, string> = { name, service, date, budget };
      Object.entries(reviewValues).forEach(([key, value]) => {
        const output = form.querySelector<HTMLElement>(`[data-review-${key}]`);
        if (output) output.textContent = value;
      });

      if (progress) progress.hidden = true;
      if (formSteps) formSteps.hidden = true;
      if (complete) {
        complete.hidden = false;
        window.requestAnimationFrame(() => complete.focus());
      }
      form.classList.add("is-complete");
      if (stepCount) stepCount.textContent = "Lista para enviar";
      if (status) status.textContent = "";
      track("contact_request_prepared", { service });
    };

    fields.forEach((field) => {
      field.addEventListener("blur", () => showError(field));
      field.addEventListener("input", () => showError(field));
    });

    form.addEventListener("input", () => {
      if (interactionTracked) return;
      interactionTracked = true;
      track("contact_form_started");
    });

    serviceInputs.forEach((input) => {
      input.addEventListener("change", () => {
        validateService();
        if (serviceHint) {
          serviceHint.textContent = serviceHints[input.value] ?? "Añade los detalles que consideres importantes.";
        }
      });
    });

    nextButtons.forEach((button) => button.addEventListener("click", continueToNextStep));
    backButtons.forEach((button) => button.addEventListener("click", () => showStep(currentStep - 1)));
    editButton?.addEventListener("click", () => showStep(steps.length - 1));
    whatsappLink?.addEventListener("click", () => track("contact_channel_opened", { channel: "whatsapp" }));
    emailLink?.addEventListener("click", () => track("contact_channel_opened", { channel: "email" }));

    form.addEventListener("submit", (event) => {
      event.preventDefault();

      if (currentStep < steps.length - 1) {
        continueToNextStep();
        return;
      }

      if (honeypot?.value) {
        if (status) status.textContent = "No pudimos preparar la solicitud. Recarga la página e inténtalo otra vez.";
        return;
      }

      const stepResults = steps.map((_, index) => validateStep(index));
      const firstInvalidStep = stepResults.findIndex((result) => !result);

      if (firstInvalidStep >= 0) {
        showStep(firstInvalidStep);
        if (status) status.textContent = "Revisa los campos marcados antes de continuar.";
        const invalidField = steps[firstInvalidStep]?.querySelector<HTMLElement>('[aria-invalid="true"]');
        invalidField?.focus();
        return;
      }

      prepareRequest();
    });

    const requestedService = new URLSearchParams(window.location.search).get("servicio");
    const matchingService = serviceInputs.find((input) => input.value === requestedService);
    if (matchingService) {
      matchingService.checked = true;
      if (serviceHint) serviceHint.textContent = serviceHints[matchingService.value];
    }

    showStep(0, false);
  }
</script>
