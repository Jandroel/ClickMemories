---
import { developerProfile, navItems, siteConfig } from "@data/site";
import BrandLogo from "@components/BrandLogo.astro";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="footer-brand" href="/" aria-label="Ir al inicio de ClickMemories"><BrandLogo variant="inverse" /></a>
      <p>{siteConfig.tagline}</p>
      <p>Fotografía y video con mirada cinematográfica desde {siteConfig.location}.</p>
      <a class="footer-creator-link" href="/quiero-una-web/">Diseño y desarrollo por {developerProfile.name} <span aria-hidden="true">↗</span></a>
    </div>
    <div>
      <h2>Explorar</h2>
      <ul>
        {navItems.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </div>
    <div>
      <h2>Contacto</h2>
      <ul>
        <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li><a href={`tel:${siteConfig.phone.replaceAll(" ", "")}`}>{siteConfig.phone}</a></li>
        <li>{siteConfig.location}</li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {year} {siteConfig.name}. Todos los derechos reservados.</span>
    <div class="footer-bottom__links">
      <a href="/privacidad/">Privacidad</a>
      <a href="/quiero-una-web/">¿Quieres una web así?</a>
      <a href="/contacto/">Ver disponibilidad</a>
    </div>
  </div>
</footer>
