---
interface ServicePath {
  label: string;
  title: string;
  outcome: string;
  description: string;
  image: string;
  imageAlt: string;
}

interface Props {
  paths: ServicePath[];
}

const { paths } = Astro.props;
---

<div class="home-service-paths" data-home-service-paths>
  <div class="home-service-paths__stage">
    {
      paths.map((path, index) => (
        <figure
          id={`home-service-panel-${index}`}
          class="home-service-paths__panel"
          role="tabpanel"
          aria-labelledby={`home-service-tab-${index}`}
          tabindex="0"
          hidden={index !== 0}
        >
          <img src={path.image} alt={path.imageAlt} width="1400" height="1100" loading={index === 0 ? "eager" : "lazy"} />
          <figcaption>
            <span>{path.label}</span>
            <strong>{path.outcome}</strong>
          </figcaption>
        </figure>
      ))
    }
    <span class="home-service-paths__frame" aria-hidden="true">ClickMemories · 2026</span>
  </div>

  <div class="home-service-paths__navigation">
    <div class="home-service-paths__tabs" role="tablist" aria-label="Explorar categorías de servicio">
      {
        paths.map((path, index) => (
          <button
            id={`home-service-tab-${index}`}
            type="button"
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`home-service-panel-${index}`}
            tabindex={index === 0 ? 0 : -1}
          >
            <span>{String(index + 1).padStart(2, "0")}</span>
            <span>
              <small>{path.label}</small>
              <strong>{path.title}</strong>
              <em>{path.description}</em>
            </span>
            <i aria-hidden="true">↗</i>
          </button>
        ))
      }
    </div>
    <a class="button button--light" href="/servicios/#servicios-a-medida">Ver todos los servicios <span aria-hidden="true">↗</span></a>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-home-service-paths]").forEach((explorer) => {
    const tabs = Array.from(explorer.querySelectorAll<HTMLButtonElement>("[role='tab']"));
    const panels = Array.from(explorer.querySelectorAll<HTMLElement>("[role='tabpanel']"));

    const activate = (nextIndex: number, moveFocus = false) => {
      tabs.forEach((tab, index) => {
        const active = index === nextIndex;
        tab.setAttribute("aria-selected", String(active));
        tab.tabIndex = active ? 0 : -1;
        panels[index].hidden = !active;
      });

      if (moveFocus) tabs[nextIndex].focus();
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activate(index));
      tab.addEventListener("pointerenter", () => activate(index));
      tab.addEventListener("focus", () => activate(index));
      tab.addEventListener("keydown", (event) => {
        let nextIndex = index;
        if (["ArrowRight", "ArrowDown"].includes(event.key)) nextIndex = (index + 1) % tabs.length;
        if (["ArrowLeft", "ArrowUp"].includes(event.key)) nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === "Home") nextIndex = 0;
        if (event.key === "End") nextIndex = tabs.length - 1;
        if (nextIndex === index) return;

        event.preventDefault();
        activate(nextIndex, true);
      });
    });
  });
</script>

<style>
  .home-service-paths {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(360px, 0.75fr);
    gap: clamp(2.5rem, 7vw, 7rem);
    align-items: center;
  }

  .home-service-paths__stage {
    position: relative;
    min-height: 680px;
    overflow: hidden;
    background: #24211d;
  }

  .home-service-paths__panel {
    position: absolute;
    inset: 0;
    margin: 0;
    outline: none;
  }

  .home-service-paths__panel[hidden] {
    display: none;
  }

  .home-service-paths__panel::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(22, 21, 19, 0.75) 0%, rgba(22, 21, 19, 0.08) 58%);
  }

  .home-service-paths__panel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: home-service-image var(--duration-narrative) var(--ease-out) both;
  }

  .home-service-paths__panel figcaption {
    position: absolute;
    right: 2rem;
    bottom: 2rem;
    left: 2rem;
    z-index: 1;
    display: grid;
    gap: 0.5rem;
    animation: home-service-copy var(--duration-medium) 90ms var(--ease-out) both;
  }

  .home-service-paths__panel figcaption span {
    color: var(--color-gold);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .home-service-paths__panel figcaption strong {
    max-width: 650px;
    color: white;
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 4vw, 4.5rem);
    line-height: 1.02;
  }

  .home-service-paths__frame {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    z-index: 2;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
  }

  .home-service-paths__navigation {
    display: grid;
    gap: 2rem;
  }

  .home-service-paths__tabs {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .home-service-paths__tabs button {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: start;
    width: 100%;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    padding: 1.5rem 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.55);
    text-align: left;
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-standard),
      padding var(--duration-fast) var(--ease-standard);
  }

  .home-service-paths__tabs button:hover,
  .home-service-paths__tabs button[aria-selected="true"] {
    color: white;
    padding-left: 0.65rem;
  }

  .home-service-paths__tabs button > span:first-child {
    color: inherit;
    font-family: var(--font-serif);
    font-size: 1.1rem;
  }

  .home-service-paths__tabs button > span:nth-child(2) {
    display: grid;
    gap: 0.25rem;
  }

  .home-service-paths__tabs small {
    color: inherit;
    font-size: 0.64rem;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .home-service-paths__tabs strong {
    color: inherit;
    font-family: var(--font-serif);
    font-size: 1.8rem;
  }

  .home-service-paths__tabs em {
    max-width: 390px;
    margin-top: 0.3rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.82rem;
    font-style: normal;
    line-height: 1.5;
  }

  .home-service-paths__tabs i {
    opacity: 0;
    font-style: normal;
    transform: translate(-0.3rem, 0.3rem);
    transition:
      opacity var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .home-service-paths__tabs button[aria-selected="true"] > span:first-child,
  .home-service-paths__tabs button[aria-selected="true"] small {
    color: var(--color-gold);
  }

  .home-service-paths__tabs button[aria-selected="true"] i {
    opacity: 1;
    transform: translate(0, 0);
  }

  .home-service-paths__navigation > .button {
    justify-self: start;
  }

  @keyframes home-service-image {
    from { opacity: 0; transform: scale(1.04); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes home-service-copy {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 980px) {
    .home-service-paths {
      grid-template-columns: 1fr;
    }

    .home-service-paths__navigation {
      display: contents;
    }

    .home-service-paths__tabs {
      order: -1;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(250px, 1fr);
      overflow-x: auto;
      scrollbar-width: none;
    }

    .home-service-paths__tabs::-webkit-scrollbar {
      display: none;
    }

    .home-service-paths__tabs button {
      min-height: 150px;
      padding-inline: 0.75rem;
    }

    .home-service-paths__navigation > .button {
      order: 3;
    }
  }

  @media (max-width: 680px) {
    .home-service-paths {
      gap: 1.4rem;
      margin-inline: -1rem;
    }

    .home-service-paths__tabs {
      grid-auto-columns: minmax(210px, 76vw);
      padding-inline: 1rem;
    }

    .home-service-paths__tabs button {
      grid-template-columns: 1.6rem 1fr auto;
      min-height: 118px;
      padding: 1rem 0.65rem;
    }

    .home-service-paths__tabs strong {
      font-size: 1.35rem;
    }

    .home-service-paths__tabs em {
      display: none;
    }

    .home-service-paths__stage {
      min-height: 500px;
    }

    .home-service-paths__panel figcaption {
      right: 1.2rem;
      bottom: 1.2rem;
      left: 1.2rem;
    }

    .home-service-paths__panel figcaption strong {
      font-size: 2.65rem;
    }

    .home-service-paths__navigation > .button {
      width: calc(100% - 2rem);
      margin-inline: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-service-paths__panel img,
    .home-service-paths__panel figcaption {
      animation: none;
    }
  }
</style>
