---
import { navItems } from "@data/site";
import BrandLogo from "@components/BrandLogo.astro";
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="nav-shell" aria-label="Navegación principal">
    <a class="brand" href="/" aria-label="Ir al inicio de ClickMemories">
      <BrandLogo />
    </a>

    <div class="nav-links" aria-label="Secciones principales">
      {
        navItems.map((item) => (
          <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
    </div>

    <a class="nav-cta" href="/contacto/">Reservar</a>

    <details class="mobile-menu">
      <summary aria-label="Abrir menú">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-menu-panel">
        {
          navItems.map((item) => (
            <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
              {item.label}
            </a>
          ))
        }
      </div>
    </details>
  </nav>
</header>
