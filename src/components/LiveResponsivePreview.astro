<div class="live-preview" data-live-preview data-size="desktop">
  <header class="live-preview__toolbar">
    <div class="live-preview__status">
      <i aria-hidden="true"></i>
      <span>Vista en vivo</span>
    </div>

    <div class="live-preview__controls" role="group" aria-label="Cambiar tamaño de la vista previa">
      <button type="button" data-preview-size="desktop" aria-pressed="true">Escritorio</button>
      <button type="button" data-preview-size="tablet" aria-pressed="false">Tablet</button>
      <button type="button" data-preview-size="mobile" aria-pressed="false">Móvil</button>
    </div>

    <a href="/" target="_blank" rel="noreferrer">Abrir sitio <span aria-hidden="true">↗</span></a>
  </header>

  <div class="live-preview__stage">
    <div class="live-preview__device">
      <div class="live-preview__browser" aria-hidden="true">
        <span></span><span></span><span></span>
        <small>clickmemories.local</small>
      </div>
      <iframe src="/" title="Vista responsive de la página de inicio de ClickMemories" loading="lazy" tabindex="-1"></iframe>
    </div>
  </div>

  <p class="live-preview__announcement" aria-live="polite">Vista de escritorio seleccionada.</p>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-live-preview]").forEach((preview) => {
    const buttons = Array.from(preview.querySelectorAll<HTMLButtonElement>("[data-preview-size]"));
    const announcement = preview.querySelector<HTMLElement>(".live-preview__announcement");
    const labels: Record<string, string> = {
      desktop: "escritorio",
      tablet: "tablet",
      mobile: "móvil"
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const size = button.dataset.previewSize ?? "desktop";
        preview.dataset.size = size;
        buttons.forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
        if (announcement) announcement.textContent = `Vista de ${labels[size]} seleccionada.`;
      });
    });
  });
</script>

<style>
