---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { id, eyebrow, title, description, align = "left" } = Astro.props;
---

<div class:list={["section-heading", align === "center" && "section-heading--center"]} data-reveal>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 id={id}>{title}</h2>
  {description && <p>{description}</p>}
</div>
