---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"trabajos">;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const projectUrl = `/trabajos/${project.id}/`;
const projectNumber = String(index + 1).padStart(2, "0");
const projectYear = project.data.date.getFullYear();
---

<article class="project-card">
  <a class="project-card__media" href={projectUrl} aria-label={`Ver historia ${project.data.title}`}>
    <img
      src={project.data.cover}
      alt={project.data.coverAlt}
      width="1400"
      height="1100"
      loading="lazy"
      style={`view-transition-name: project-${project.id};`}
    />
    <span class="project-card__number" aria-hidden="true">{projectNumber}</span>
    <span class="project-card__action">Explorar caso <span aria-hidden="true">↗</span></span>
  </a>

  <div class="project-card__body">
    <div class="project-card__kicker">
      <p>{project.data.category}</p>
      <span>{projectYear}</span>
    </div>
    <h3><a href={projectUrl}>{project.data.title}</a></h3>
    <div class="project-card__meta">
      <span>{project.data.location}</span>
      <span aria-hidden="true">·</span>
      <span>{project.data.duration}</span>
    </div>
  </div>
</article>
