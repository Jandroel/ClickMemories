---
interface ServiceOffer {
  title: string;
  description: string;
  details: string[];
  startingAt: string;
  label: string;
  outcome: string;
  image: string;
  imageAlt: string;
}

interface Props {
  offers: ServiceOffer[];
}

const { offers } = Astro.props;
---

<div class="service-explorer" data-service-explorer>
  <div class="service-explorer__tabs" role="tablist" aria-label="Elige un servicio para conocer sus detalles">
    {
      offers.map((offer, index) => (
        <button
          id={`service-tab-${index}`}
          class="service-explorer__tab"
          type="button"
          role="tab"
          aria-selected={index === 0 ? "true" : "false"}
          aria-controls={`service-panel-${index}`}
          tabindex={index === 0 ? 0 : -1}
        >
          <span class="service-explorer__number">{String(index + 1).padStart(2, "0")}</span>
          <span>
            <small>{offer.label}</small>
            <strong>{offer.title}</strong>
          </span>
          <span class="service-explorer__arrow" aria-hidden="true">↗</span>
        </button>
      ))
    }
  </div>

  <div class="service-explorer__panels">
    {
      offers.map((offer, index) => (
        <article
          id={`service-panel-${index}`}
          class="service-explorer__panel"
          role="tabpanel"
          aria-labelledby={`service-tab-${index}`}
          tabindex="0"
          hidden={index !== 0}
        >
          <div class="service-explorer__media">
            <img src={offer.image} alt={offer.imageAlt} width="1200" height="900" loading={index === 0 ? "eager" : "lazy"} />
            <span>{offer.label}</span>
          </div>

          <div class="service-explorer__content">
            <p class="eyebrow">El resultado</p>
            <h3>{offer.outcome}</h3>
            <p>{offer.description}</p>

            <div class="service-explorer__details">
              <ul aria-label={`Qué incluye ${offer.title}`}>
                {offer.details.map((detail) => <li>{detail}</li>)}
              </ul>
              <div class="service-explorer__investment">
                <span>Inversión referencial</span>
                <strong>{offer.startingAt}</strong>
              </div>
            </div>

            <a class="button button--primary" href="/contacto/#solicitud">Consultar este servicio <span aria-hidden="true">↗</span></a>
          </div>
        </article>
      ))
    }
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-service-explorer]").forEach((explorer) => {
    const tabs = Array.from(explorer.querySelectorAll<HTMLButtonElement>("[role='tab']"));
    const panels = Array.from(explorer.querySelectorAll<HTMLElement>("[role='tabpanel']"));

    const activateTab = (nextIndex: number, moveFocus = false) => {
      tabs.forEach((tab, index) => {
        const isActive = index === nextIndex;
        tab.setAttribute("aria-selected", String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
        panels[index].hidden = !isActive;
      });

      if (moveFocus) tabs[nextIndex].focus();
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activateTab(index));
      tab.addEventListener("keydown", (event) => {
        let nextIndex = index;

        if (["ArrowRight", "ArrowDown"].includes(event.key)) nextIndex = (index + 1) % tabs.length;
        if (["ArrowLeft", "ArrowUp"].includes(event.key)) nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === "Home") nextIndex = 0;
        if (event.key === "End") nextIndex = tabs.length - 1;
        if (nextIndex === index) return;

        event.preventDefault();
        activateTab(nextIndex, true);
      });
    });
  });
</script>

<style>
  .service-explorer {
    display: grid;
    grid-template-columns: minmax(250px, 0.72fr) minmax(0, 2fr);
    gap: clamp(1.5rem, 4vw, 4.5rem);
    align-items: start;
  }

  .service-explorer__tabs {
    position: sticky;
    top: 6.5rem;
    display: grid;
    border-top: 1px solid var(--color-line);
  }

  .service-explorer__tab {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.9rem;
    align-items: center;
    width: 100%;
    border: 0;
    border-bottom: 1px solid var(--color-line);
    padding: 1rem 0.2rem;
    background: transparent;
    color: var(--color-muted);
    text-align: left;
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-standard),
      padding var(--duration-fast) var(--ease-standard);
  }

  .service-explorer__tab:hover,
  .service-explorer__tab[aria-selected="true"] {
    color: var(--color-ink);
    padding-left: 0.65rem;
  }

  .service-explorer__number,
  .service-explorer__tab small {
    color: inherit;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .service-explorer__tab > span:nth-child(2) {
    display: grid;
    gap: 0.15rem;
  }

  .service-explorer__tab strong {
    font-size: 0.94rem;
  }

  .service-explorer__arrow {
    opacity: 0;
    transform: translate(-0.25rem, 0.25rem);
    transition:
      opacity var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .service-explorer__tab[aria-selected="true"] .service-explorer__number {
    color: var(--color-clay);
  }

  .service-explorer__tab[aria-selected="true"] .service-explorer__arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  .service-explorer__panel {
    outline: none;
  }

  .service-explorer__panel[hidden] {
    display: none;
  }

  .service-explorer__media {
    position: relative;
    min-height: 430px;
    overflow: hidden;
    background: var(--color-cream);
  }

  .service-explorer__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(22, 21, 19, 0.5), transparent 45%);
    pointer-events: none;
  }

  .service-explorer__media img {
    width: 100%;
    height: 100%;
    min-height: 430px;
    object-fit: cover;
    animation: service-reveal var(--duration-medium) var(--ease-out) both;
  }

  .service-explorer__media > span {
    position: absolute;
    right: 1.2rem;
    bottom: 1.1rem;
    z-index: 1;
    color: white;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .service-explorer__content {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(240px, 0.8fr);
    gap: 0.9rem 2rem;
    padding-top: 1.7rem;
    animation: service-reveal var(--duration-medium) 80ms var(--ease-out) both;
  }

  .service-explorer__content .eyebrow,
  .service-explorer__content h3,
  .service-explorer__content > p {
    grid-column: 1;
  }

  .service-explorer__content h3 {
    max-width: 650px;
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 4vw, 3.8rem);
  }

  .service-explorer__content > p:not(.eyebrow) {
    max-width: 620px;
    font-size: 1rem;
  }

  .service-explorer__details {
    grid-column: 2;
    grid-row: 1 / span 4;
    display: grid;
    align-content: start;
    gap: 1.4rem;
    border-left: 1px solid var(--color-line);
    padding-left: 1.5rem;
  }

  .service-explorer__details ul {
    display: grid;
    gap: 0.75rem;
  }

  .service-explorer__details li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .service-explorer__details li::before {
    content: "";
    position: absolute;
    top: 0.7em;
    left: 0;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: var(--radius-round);
    background: var(--color-clay);
  }

  .service-explorer__investment {
    display: grid;
    gap: 0.2rem;
    border-top: 1px solid var(--color-line);
    padding-top: 1rem;
  }

  .service-explorer__investment span {
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .service-explorer__investment strong {
    font-family: var(--font-serif);
    font-size: 1.35rem;
  }

  .service-explorer__content .button {
    grid-column: 1;
    justify-self: start;
    margin-top: 0.6rem;
  }

  @keyframes service-reveal {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 900px) {
    .service-explorer {
      grid-template-columns: 1fr;
    }

    .service-explorer__tabs {
      position: static;
      grid-auto-flow: column;
      grid-auto-columns: minmax(205px, 1fr);
      overflow-x: auto;
      scrollbar-width: none;
    }

    .service-explorer__tabs::-webkit-scrollbar {
      display: none;
    }

    .service-explorer__tab {
      min-height: 76px;
      padding-inline: 0.6rem;
    }

    .service-explorer__tab:hover,
    .service-explorer__tab[aria-selected="true"] {
      padding-left: 0.6rem;
      border-bottom-color: var(--color-ink);
    }
  }

  @media (max-width: 680px) {
    .service-explorer {
      gap: 1.25rem;
      margin-inline: -1rem;
    }

    .service-explorer__tabs {
      padding-inline: 1rem;
    }

    .service-explorer__panel {
      padding-inline: 1rem;
    }

    .service-explorer__media,
    .service-explorer__media img {
      min-height: 360px;
    }

    .service-explorer__content {
      grid-template-columns: 1fr;
    }

    .service-explorer__content .eyebrow,
    .service-explorer__content h3,
    .service-explorer__content > p,
    .service-explorer__details,
    .service-explorer__content .button {
      grid-column: 1;
    }

    .service-explorer__details {
      grid-row: auto;
      border-top: 1px solid var(--color-line);
      border-left: 0;
      padding-top: 1.25rem;
      padding-left: 0;
    }

    .service-explorer__content .button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-explorer__media img,
    .service-explorer__content {
      animation: none;
    }
  }
</style>
